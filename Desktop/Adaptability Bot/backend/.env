# ============================================================================
# CHATBOT KNOWLEDGE FILE CONFIGURATION
# ============================================================================

# Choose which knowledge base to use:
KNOWLEDGE_FILE=IT_Business_Knowledge.json

# Other options (uncomment the one you want):
# KNOWLEDGE_FILE=chatbot_knowledge.json          # Default general purpose
# KNOWLEDGE_FILE=restaurant_knowledge.json       # Restaurant example
# KNOWLEDGE_FILE=my_custom_knowledge.json        # Your custom file

# Config file (usually no need to change)
CONFIG_FILE=chatbot_config.json

# Data directory (usually no need to change)
DATA_DIR=data

# ============================================================================
# OTHER SETTINGS
# ============================================================================

APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# CORS Settings
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19000,http://localhost:19006,exp://localhost:8081